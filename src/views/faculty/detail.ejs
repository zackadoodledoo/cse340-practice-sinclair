<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .faculty-detail {
            background-color: #ffffff;
            border: 1px solid #d0d8db;
            border-radius: 8px;
            padding: 30px;
            max-width: 600px;
            margin: 20px auto;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .faculty-detail h2 {
            color: #3a5a78;
            border-bottom: 3px solid #9cc5a1;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .detail-row {
            margin-bottom: 18px;
            padding-bottom: 12px;
            border-bottom: 1px solid #e8f1f2;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            display: block;
            font-weight: 600;
            color: #2f3e46;
            font-size: 0.95em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .detail-value {
            color: #555;
            font-size: 1.05em;
            padding-left: 10px;
            border-left: 4px solid #9cc5a1;
        }

        .contact-link {
            color: #3a5a78;
            text-decoration: none;
            font-weight: 500;
        }

        .contact-link:hover {
            color: #9cc5a1;
            text-decoration: underline;
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #e8f1f2;
            color: #3a5a78;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            transition: background-color 0.3s, color 0.3s;
        }

        .back-link:hover {
            background-color: #9cc5a1;
            color: #ffffff;
        }

        .error-message {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
        }

        @media (max-width: 600px) {
            .faculty-detail {
                padding: 20px;
                margin: 15px auto;
            }
        }
    </style>
</head>
<body>
    <h1><%= title %></h1>
    
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/faculty">Faculty Directory</a></li>
        </ul>
    </nav>

    <% if (faculty) { %>
        <div class="faculty-detail">
            <h2><%= faculty.name %></h2>
            
            <div class="detail-row">
                <span class="detail-label">Department</span>
                <div class="detail-value"><%= faculty.department %></div>
            </div>

            <div class="detail-row">
                <span class="detail-label">Title</span>
                <div class="detail-value"><%= faculty.title %></div>
            </div>

            <div class="detail-row">
                <span class="detail-label">Office</span>
                <div class="detail-value"><%= faculty.office %></div>
            </div>

            <div class="detail-row">
                <span class="detail-label">Email</span>
                <div class="detail-value">
                    <a href="mailto:<%= faculty.email %>" class="contact-link"><%= faculty.email %></a>
                </div>
            </div>

            <div class="detail-row">
                <span class="detail-label">Phone</span>
                <div class="detail-value">
                    <a href="tel:<%= faculty.phone %>" class="contact-link"><%= faculty.phone %></a>
                </div>
            </div>

            <a href="/faculty" class="back-link">← Back to Faculty Directory</a>
        </div>
    <% } else { %>
        <div class="error-message">
            <p>Faculty member not found. <a href="/faculty">Return to faculty directory</a></p>
        </div>
    <% } %>
</body>
</html>
