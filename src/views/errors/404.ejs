<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .error-container {
            text-align: center;
            padding: 40px 20px;
        }
        .error-code {
            font-size: 4em;
            color: #3a5a78;
            margin: 20px 0;
        }
        .error-message {
            font-size: 1.5em;
            color: #666;
            margin-bottom: 30px;
        }
        .back-home {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 24px;
            background-color: #9cc5a1;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
        }
        .back-home:hover {
            background-color: #7aa987;
        }
    </style>
</head>
<body>
    <h1><%= title %></h1>
    
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/faculty">Faculty Directory</a></li>
        </ul>
    </nav>

    <div class="error-container">
        <div class="error-code">404</div>
        <div class="error-message"><%= error %></div>
        <p>The page you're looking for couldn't be found.</p>
        <a href="/" class="back-home">← Back to Home</a>
    </div>
</body>
</html>
